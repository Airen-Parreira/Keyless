-- ============================================================
-- TRACKER LOOP (Updates UI Text & Manual Button State)
-- ============================================================
RunService.Heartbeat:Connect(function()
    -- Missions
    local cLabel = getLabel(paths.CashMission)
    local jLabel = getLabel(paths.JunkMission)
    local cText = cLabel and cLabel.Text or "--:--"
    local jText = jLabel and jLabel.Text or "--:--"

    local cSeconds = parseTimer(cText)
    local jSeconds = parseTimer(jText)

    -- A timer going UP from one tick to the next means it respawned
    if cSeconds and state.lastCashSeconds and cSeconds > state.lastCashSeconds then
        state.cashSpawned = true
    end
    if jSeconds and state.lastJunkSeconds and jSeconds > state.lastJunkSeconds then
        state.junkSpawned = true
    end
    state.lastCashSeconds = cSeconds or state.lastCashSeconds
    state.lastJunkSeconds = jSeconds or state.lastJunkSeconds

    local cColor = state.cashSpawned and Theme.Success or Theme.TextSecondary
    local jColor = state.junkSpawned and Theme.Success or Theme.TextSecondary
    MissionTimersLabel.Text = string.format(
        '<font color="%s">Cash: %s</font>  |  <font color="%s">Junk: %s</font>',
        toHex(cColor), cText, toHex(jColor), jText
    )

    state.missionsReady = state.cashSpawned or state.junkSpawned

    if state.missionsReady then
        ManualMissionBtn.BackgroundColor3 = Theme.SuccessBg
        ManualMissionBtn.TextColor3 = Theme.Success
        ManualMissionBtn.Text = "MANUAL COLLECT (READY)"
    else
        ManualMissionBtn.BackgroundColor3 = Theme.Idle
        ManualMissionBtn.TextColor3 = Theme.TextSecondary
        ManualMissionBtn.Text = "MANUAL COLLECT (WAITING)"
    end

    -- Containers
    local portL = getLabel(paths.PortContainer)
    local junkL = getLabel(paths.JunkContainer)
    local auctL = getLabel(paths.AuctContainer)

    local portText = portL and portL.Text or "--:--"
    local junkText = junkL and junkL.Text or "--:--"
    local auctText = auctL and auctL.Text or "--:--"

    local portSeconds = parseTimer(portText)
    local junkSeconds = parseTimer(junkText)
    local auctSeconds = parseTimer(auctText)

    if portSeconds and state.lastPortSeconds and portSeconds > state.lastPortSeconds then
        state.portSpawned = true
    end
    if junkSeconds and state.lastJunkyardSeconds and junkSeconds > state.lastJunkyardSeconds then
        state.junkyardSpawned = true
    end
    if auctSeconds and state.lastAuctionSeconds and auctSeconds > state.lastAuctionSeconds then
        state.auctionSpawned = true
    end
    state.lastPortSeconds = portSeconds or state.lastPortSeconds
    state.lastJunkyardSeconds = junkSeconds or state.lastJunkyardSeconds
    state.lastAuctionSeconds = auctSeconds or state.lastAuctionSeconds

    local portColor = state.portSpawned and Theme.Success or Theme.TextSecondary
    local junkColor = state.junkyardSpawned and Theme.Success or Theme.TextSecondary
    local auctColor = state.auctionSpawned and Theme.Success or Theme.TextSecondary

    ContainerTimersLabel.Text = string.format(
        '<font color="%s">Port: %s</font>\n<font color="%s">Junkyard: %s</font>\n<font color="%s">Auction: %s</font>',
        toHex(portColor), portText, toHex(junkColor), junkText, toHex(auctColor), auctText
    )

    state.containersReady = state.portSpawned or state.junkyardSpawned or state.auctionSpawned

    if state.containersReady then
        ManualContainerBtn.BackgroundColor3 = Theme.SuccessBg
        ManualContainerBtn.TextColor3 = Theme.Success
        ManualContainerBtn.Text = "MANUAL COLLECT (READY)"
    else
        ManualContainerBtn.BackgroundColor3 = Theme.Idle
        ManualContainerBtn.TextColor3 = Theme.TextSecondary
        ManualContainerBtn.Text = "MANUAL COLLECT (WAITING)"
    end
end)

