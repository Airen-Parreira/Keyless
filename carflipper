-- Maps a container's display name to its timer path + the state keys
-- the Heartbeat loop uses to track it
local containerInfo = {
    Port     = {path = paths.PortContainer, spawnedKey = "portSpawned",     lastKey = "lastPortSeconds"},
    Junkyard = {path = paths.JunkContainer, spawnedKey = "junkyardSpawned", lastKey = "lastJunkyardSeconds"},
    Auction  = {path = paths.AuctContainer, spawnedKey = "auctionSpawned",  lastKey = "lastAuctionSeconds"},
}

-- Path to the actual container instance (the one holding the ProximityPrompt),
-- as opposed to `paths.PortContainer` etc which point at the TimerLabel
local containerObjectPaths = {
    Port     = {"Containers", "Port", "Container"},
    Junkyard = {"Containers", "Junkyard", "Container"},
    Auction  = {"Containers", "Auction", "Container"},
}

local function getContainerPosition(container)
    local ok, pivot = pcall(function() return container:GetPivot() end)
    if ok and pivot then
        return pivot.Position
    end
    return container.Position
end

-- Simulates holding down the interact key on a ProximityPrompt
local function fireProximityPrompt(prompt)
    if not prompt then return false end
    prompt:InputHoldBegin()
    task.wait((prompt.HoldDuration or 0) + 0.05)
    prompt:InputHoldEnd()
    return true
end

local function collectContainer(locName)
    local objPath = containerObjectPaths[locName]
    local container = objPath and getLabel(objPath)

    if container then
        local originalPosition = root.CFrame
        root.CFrame = CFrame.new(getContainerPosition(container))
        task.wait(0.6)

        local prompt = container:FindFirstChild("ProximityPrompt")
        if fireProximityPrompt(prompt) then
            logMsg("📦 Collected " .. locName .. " container!", Color3.fromRGB(100, 180, 230))
        else
            logMsg("⚠ No ProximityPrompt found on " .. locName .. " container", Theme.Danger)
        end

        task.wait(0.3)
        root.CFrame = originalPosition
        task.wait(0.2)
    else
        logMsg("⚠ Could not find " .. locName .. " container in workspace", Theme.Danger)
    end

    -- Clear the spawned flag and rebase the timer baseline, same pattern as completeMission
    local info = containerInfo[locName]
    if info then
        state[info.spawnedKey] = false
        local lbl = getLabel(info.path)
        state[info.lastKey] = lbl and parseTimer(lbl.Text) or state[info.lastKey]
    end
end

local function autoContainerLoop()
    while state.autoContainerRunning do
        if state.portSpawned then collectContainer("Port") end
        if state.junkyardSpawned then collectContainer("Junkyard") end
        if state.auctionSpawned then collectContainer("Auction") end
        task.wait(1)
    end
end

