local function completeMission(missionType)
    local targetPos = missionPositions[missionType]
    if not targetPos then return end

    local originalPosition = root.CFrame
    root.CFrame = CFrame.new(targetPos)
    task.wait(0.6)

    game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("Base"):WaitForChild("LoadJunk"):FireServer(missionType)
    task.wait(0.4)
    game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("Base"):WaitForChild("CollectJunk"):FireServer()
    task.wait(0.5)

    game:GetService("VirtualInputManager"):SendKeyEvent(true, Enum.KeyCode.F, false, game)
    task.wait(0.05)
    game:GetService("VirtualInputManager"):SendKeyEvent(false, Enum.KeyCode.F, false, game)
    task.wait(0.5)

    root.CFrame = originalPosition
    task.wait(0.3)

    -- Mark this mission as no longer spawned, and rebase the timer
    -- baseline so the next countdown tick isn't mistaken for a new spawn
    if missionType == "Cash" then
        state.cashSpawned = false
        local lbl = getLabel(paths.CashMission)
        state.lastCashSeconds = lbl and parseTimer(lbl.Text) or state.lastCashSeconds
    elseif missionType == "Junk" then
        state.junkSpawned = false
        local lbl = getLabel(paths.JunkMission)
        state.lastJunkSeconds = lbl and parseTimer(lbl.Text) or state.lastJunkSeconds
    end

    logMsg("✅ Completed " .. missionType .. " mission", Theme.Success)
end

local function autoMissionLoop()
    while state.autoMissionRunning do
        if state.cashSpawned then 
            completeMission("Cash") 
        end
        
        if state.junkSpawned then 
            completeMission("Junk") 
        end
        
        task.wait(1) -- Polls every second just like the container loop
    end
end

