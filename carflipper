local function logMsg(msg, color)
    logCount = logCount + 1
    local lbl = Instance.new("TextLabel")
    lbl.Name = "LogMsg_" .. logCount
    lbl.LayoutOrder = logCount
    lbl.Size = UDim2.new(1, 0, 0, 15)
    lbl.BackgroundTransparency = 1
    lbl.Text = " " .. msg
    lbl.TextColor3 = color or Theme.TextSecondary
    lbl.TextSize = 12
    lbl.Font = Enum.Font.Gotham
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = LogScroll

    local allLogs = {}
    for _, child in ipairs(LogScroll:GetChildren()) do
        if child:IsA("TextLabel") then
            table.insert(allLogs, child)
        end
    end

    if #allLogs > maxLogs then
        table.sort(allLogs, function(a, b) return a.LayoutOrder < b.LayoutOrder end)
        allLogs[1]:Destroy()
    end

    task.defer(function()
        LogScroll.CanvasPosition = Vector2.new(0, LogScroll.AbsoluteCanvasSize.Y)
    end)
end

